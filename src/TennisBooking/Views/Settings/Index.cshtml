@model SettingsIndexViewModel
@{
    Layout = null;
}
<!doctype html>
<html lang="uk">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Налаштування бронювання</title>
    <script src="https://unpkg.com/htmx.org@2.0.4"></script>
    <style>
        :root {
            color-scheme: dark;
            --bg: #070b13;
            --panel: rgba(16, 24, 39, .76);
            --panel-strong: rgba(22, 33, 51, .94);
            --ink: #f6f0df;
            --muted: #96a2b4;
            --line: rgba(255, 255, 255, .11);
            --field: rgba(255, 255, 255, .08);
            --field-border: rgba(255, 255, 255, .16);
            --accent: #f6c85f;
            --accent-ink: #191103;
            --cyan: #66e3d1;
            --danger: #ff9a84;
            --danger-bg: rgba(255, 95, 72, .12);
            --shadow: rgba(0, 0, 0, .48);
        }

        * {
            box-sizing: border-box;
        }

        body {
            margin: 0;
            min-height: 100vh;
            color: var(--ink);
            font-family: ui-serif, Georgia, Cambria, "Times New Roman", serif;
            background:
                radial-gradient(circle at 16% 8%, rgba(102, 227, 209, .20), transparent 24rem),
                radial-gradient(circle at 84% 18%, rgba(246, 200, 95, .18), transparent 26rem),
                linear-gradient(135deg, #05070d 0%, #0a1222 52%, #101827 100%);
        }

        body::before {
            content: "";
            position: fixed;
            inset: 0;
            pointer-events: none;
            opacity: .22;
            background-image:
                linear-gradient(rgba(255,255,255,.05) 1px, transparent 1px),
                linear-gradient(90deg, rgba(255,255,255,.05) 1px, transparent 1px);
            background-size: 52px 52px;
            mask-image: linear-gradient(to bottom, black, transparent 78%);
        }

        main {
            position: relative;
            width: min(980px, calc(100% - 32px));
            margin: 0 auto;
            padding: 58px 0;
        }

        .hero {
            display: grid;
            grid-template-columns: 1fr auto;
            gap: 24px;
            align-items: end;
            margin-bottom: 30px;
        }

        .eyebrow {
            margin: 0 0 12px;
            color: var(--cyan);
            font: 800 .78rem ui-sans-serif, "Avenir Next", "Segoe UI", sans-serif;
            letter-spacing: .18em;
            text-transform: uppercase;
        }

        h1 {
            margin: 0 0 12px;
            max-width: 700px;
            font-size: clamp(3rem, 9vw, 7.2rem);
            line-height: .82;
            letter-spacing: -.075em;
        }

        .lede {
            margin: 0;
            max-width: 620px;
            color: var(--muted);
            font-size: 1.12rem;
            line-height: 1.55;
        }

        .dashboard-link {
            color: var(--ink);
            text-decoration: none;
            border: 1px solid var(--line);
            border-radius: 999px;
            padding: 12px 16px;
            background: rgba(255, 255, 255, .06);
            box-shadow: inset 0 1px 0 rgba(255,255,255,.08);
            white-space: nowrap;
            font: 800 .9rem ui-sans-serif, "Avenir Next", "Segoe UI", sans-serif;
        }

        .panel {
            position: relative;
            overflow: hidden;
            border: 1px solid var(--line);
            border-radius: 32px;
            background:
                linear-gradient(135deg, rgba(255,255,255,.08), transparent 32%),
                var(--panel);
            box-shadow: 0 30px 90px var(--shadow);
            backdrop-filter: blur(18px);
        }

        .panel::before {
            content: "";
            position: absolute;
            inset: 0 0 auto;
            height: 3px;
            background: linear-gradient(90deg, var(--cyan), var(--accent));
        }

        .schedule-list {
            display: grid;
            gap: 0;
        }

        .empty {
            padding: 42px;
            color: var(--muted);
        }

        @@media (max-width: 720px) {
            main {
                width: min(100% - 20px, 980px);
                padding: 32px 0;
            }

            .hero {
                display: block;
            }

            .dashboard-link {
                display: inline-block;
                margin-top: 18px;
            }
        }
    </style>
</head>
<body>
<main>
    <section class="hero">
        <div>
            <p class="eyebrow">Тенісна автоматизація</p>
            <h1>Розклад бронювання</h1>
            <p class="lede">Змінюй щотижневий час корту. Збереження оновлює PostgreSQL і одразу перереєстровує recurring job у Hangfire без рестарту застосунку.</p>
        </div>
        <a class="dashboard-link" href="/hangfire">Панель Hangfire</a>
    </section>

    <section class="panel" aria-label="Розклади бронювання">
        @if (Model.UserConfigs.Count == 0)
        {
            <div class="empty">Налаштування бронювання не знайдено.</div>
        }
        else
        {
            <div class="schedule-list">
                @foreach (var config in Model.UserConfigs)
                {
                    <partial name="_UserConfigRow" model="config" />
                }
            </div>
        }
    </section>
</main>
</body>
</html>
